SELECT product_name,
   TO_CHAR(added_date, 'DD-MONTH-YYYY') AS formated_date
 FROM products;
 
--use of DATE_PART() to get specific part of date
--EXTRACT the day of the week from added_date


SELECT product_name , added_date,
     DATE_PART('dow',added_date) AS day_of_week,
	  DATE_PART('quarter',added_date) AS quarter_
FROM products;	 


--DATE_TRUNC()-truncate date to precision
--truncate added_date to the start of the month.

SELECT product_name ,
DATE_TRUNC('week', added_date) AS month_start
FROM products;

--Interval function add or substract time inteval
--add 6 months in added_date

SELECT product_name , added_date,
 added_date+INTERVAL '6 days' AS new_date
 FROM products;

 --current time
 SELECT CURRENT_TIME AS currenttime;

-- TO_DATE -convert string to date
--convert a string to a date format
SELECT TO_DATE('26-11-2008','DD-MM-YYYY') AS converted_date;

 
