		(103,'IT'),
		(104,'HR');

SELECT e.first_name,e.last_name,
       d.department_id,d.department_name
FROM Employee_3 e
INNER JOIN
Departments d
ON e.department_id=d.department_id;

--LEFT JOIN 
--Retrive all employee_3 and their departments names , including those without a department

SELECT e.first_name,e.last_name,
       d.department_id,d.department_name
FROM Employee_3 e
LEFT JOIN 
Departments d
ON e.department_id=d.department_id;


--RIGHT JOIN 
SELECT e.first_name,e.last_name,
       d.department_id,d.department_name
FROM Employee_3 e
RIGHT JOIN 
Departments d
ON e.department_id=d.department_id;

--FULL OUTER JOIN 
SELECT e.first_name,e.last_name,
       d.department_id,d.department_name
FROM Employee_3 e
FULL OUTER JOIN 
Departments d
ON e.department_id=d.department_id;
