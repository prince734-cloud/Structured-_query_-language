SELECT * FROM products;
-- DATE AND TIME FUNCTIONS

--use of now() function
SELECT NOW() AS currentdate_time;

--use of current date function
SELECT CURRENT_DATE AS present_date;

-- Get number of days from today to added date
SELECT (CURRENT_DATE-added_date) AS total_days
FROM products;

--use of extract()-to Extract parts of a date(year , month, day ) from added_date column.

SELECT  product_name,
     EXTRACT(YEAR FROM added_date) AS year_added
FROM products;

SELECT  product_name,
     EXTRACT(MONTH FROM added_date) AS Month_added,
	 EXTRACT(DAY FROM added_date) AS Day_added
FROM products;

--use of age() to calculate age between dates
 SELECT product_name,
   AGE(CURRENT_DATE , added_date) AS current_age
 FROM products;

 -- use of To_char() format dates as strings.
 SELECT product_name,
   TO_CHAR(added_date, 'DD-MONTH-YYYY') AS formated_date
 FROM products;
 
